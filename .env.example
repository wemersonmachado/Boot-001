# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TRADER BOT 001 — VARIÁVEIS DE AMBIENTE (.env)                              ║
# ║  Copie este arquivo para  .env  e preencha com SEUS valores.               ║
# ║  ⚠️  NUNCA suba o .env real para o GitHub. Só este .env.example.            ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Binance (Futures USDT-M) ────────────────────────────────────────────────
# Crie em: Binance > API Management. Permissões: Enable Futures (NÃO habilite
# saques/withdrawals). Restrinja por IP ao IP da sua VM Oracle.
BINANCE_API_KEY=cole_sua_api_key_aqui
BINANCE_SECRET_KEY=cole_sua_secret_key_aqui
# true = testnet (sem dinheiro real) · false = conta REAL
BINANCE_TESTNET=false

# ── Telegram ────────────────────────────────────────────────────────────────
# Token do @BotFather. CHAT_ID = seu chat pessoal (use @userinfobot p/ descobrir).
TELEGRAM_TOKEN=cole_o_token_do_botfather
TELEGRAM_CHAT_ID=seu_chat_id_pessoal
# Canais (opcionais) — deixe vazio se não usar
TELEGRAM_CHANNEL_ID=
TELEGRAM_VIP_ID=

# ── Claude Brain (opcional — filtro de IA) ──────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
CLAUDE_BRAIN_BUDGET_USD=5.0

# ── APIs de dados de mercado (opcionais) ────────────────────────────────────
# CoinMarketCap (free: 333 req/dia) — https://pro.coinmarketcap.com/account
CMC_API_KEY=
# CoinMarketCal (free: 100 req/dia) — https://coinmarketcal.com/en/developer
COINMARKETCAL_API_KEY=

# ── Servidor ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WEBHOOK_SECRET=defina_um_segredo_qualquer

# ── Risco (padrões; o dashboard sobrescreve em runtime) ─────────────────────
DEFAULT_RISK_PCT=1.0
MAX_OPEN_TRADES=5
