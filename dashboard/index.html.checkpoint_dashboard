<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>TRADER 001 — Dashboard</title>
<style>
/* ═══════════════════════════════════════════
   TRADER 001 — Dark Gold v4  (wizard à esquerda, tema suave)
═══════════════════════════════════════════ */
:root {
  --bg:        #09090f;
  --card:      #141420;
  --card2:     #0f0f1a;
  --border:    #1e1e30;
  --border2:   #2a2a42;
  --gold:      #F0C000;
  --gold2:     #FFD700;
  --gold-dim:  rgba(240,192,0,.12);
  --text:      #eeeef5;
  --muted:     #8888aa;
  --dim:       #2e2e44;
  --up:        #00C896;
  --up-bg:     rgba(0,200,150,.1);
  --down:      #FF4D4D;
  --down-bg:   rgba(255,77,77,.1);
  --blue:      #5B9CF6;
  --purple:    #B87EFB;
  --wz-w:      440px;
  --r:         12px;
}
body.light-theme {
  --bg:        #f3f4f6;
  --card:      #ffffff;
  --card2:     #f9fafb;
  --border:    #e5e7eb;
  --border2:   #d1d5db;
  --gold:      #b45309;
  --gold2:     #d97706;
  --gold-dim:  rgba(217,119,6,.08);
  --text:      #111827;
  --muted:     #4b5563;
  --dim:       #e5e7eb;
  --up:        #047857;
  --up-bg:     rgba(4,120,87,.08);
  --down:      #b91c1c;
  --down-bg:   rgba(185,28,28,.08);
  --blue:      #1d4ed8;
  --purple:    #6d28d9;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{
  font-family:'Segoe UI',system-ui,-apple-system,sans-serif;
  background:var(--bg);color:var(--text);font-size:15px;
  display:flex;height:100vh;-webkit-font-smoothing:antialiased;
  transition: background-color 0.25s, color 0.25s;
}
.wizard, .wz-hdr, .hdr, .sc, .mc, .card, .ob, .s-inp, .ptog, .qb, .step-hdr, .step-body, .tbl tr {
  transition: background-color 0.25s, border-color 0.25s, color 0.25s;
}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--dim);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--border2)}

/* ══ WIZARD (ESQUERDA) ══ */
.wizard{
  width:var(--wz-w);min-width:var(--wz-w);
  background:#0b0b16;border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow-y:auto;overflow-x:hidden;flex-shrink:0;
}
.wz-hdr{
  padding:18px 18px 15px;border-bottom:1px solid var(--border);
  flex-shrink:0;background:#0d0d1a;
}
.wz-logo{font-size:11px;font-weight:900;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;opacity:.8}
.wz-title{font-size:16px;font-weight:900;margin-bottom:4px;letter-spacing:-.3px}
.wz-sub{font-size:11px;color:var(--muted);font-weight:400;line-height:1.5}
.wz-prog{margin-top:13px}
.wz-prog-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden;margin-bottom:5px}
.wz-prog-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold2));transition:width .4s}
.wz-prog-txt{font-size:10px;color:var(--muted);display:flex;justify-content:space-between;font-weight:600}

.wz-body{padding:14px 16px;flex:1}

/* Step */
.step{border:1.5px solid var(--border);border-radius:10px;margin-bottom:8px;overflow:hidden;transition:border-color .2s}
.step.active{border-color:var(--gold)}
.step.done{border-color:rgba(0,200,150,.4)}
.step.locked{opacity:.4;pointer-events:none}
.step.sinais-skip .step-hdr{pointer-events:none;cursor:default;opacity:.45}
.step.sinais-skip .step-body{display:none!important}
.step-hdr{
  display:flex;align-items:center;gap:10px;padding:12px 14px;
  cursor:pointer;background:var(--card2);user-select:none;
}
.step-num{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;flex-shrink:0}
.step.active .step-num{background:var(--gold);color:#000}
.step.done   .step-num{background:var(--up);color:#000}
.step.locked .step-num,.step.pending .step-num{background:var(--dim);color:var(--muted)}
.step-ttl{flex:1;font-size:13px;font-weight:800}
.step-cur{font-size:11px;color:var(--gold);font-weight:700}
.step-ico{font-size:13px;color:var(--muted)}
.step-body{padding:14px;background:rgba(0,0,0,.3);display:none}
.step.active .step-body{display:block}

/* Option grid */
.og{display:grid;gap:7px}
.og2{grid-template-columns:1fr 1fr}
.og3{grid-template-columns:1fr 1fr 1fr}
.ob{
  padding:11px 8px;border-radius:9px;border:1.5px solid var(--border);
  background:var(--card);color:var(--text);font-size:12px;font-weight:700;
  cursor:pointer;text-align:center;transition:all .15s;line-height:1.6;
}
.ob:hover{border-color:rgba(240,192,0,.5);background:rgba(240,192,0,.05);color:var(--gold)}
.ob.sel{border-color:var(--gold);background:rgba(240,192,0,.1);color:var(--gold)}
.ob.sp2{grid-column:span 2}.ob.sp3{grid-column:span 3}
.s-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin:11px 0 6px;font-weight:700}
.s-lbl:first-child{margin-top:0}
.s-inp{
  width:100%;padding:9px 12px;border-radius:9px;
  background:var(--card);border:1.5px solid var(--border);
  color:var(--text);font-size:13px;font-weight:700;outline:none;transition:border-color .15s;
}
.s-inp:focus{border-color:var(--gold)}
.s-conf{
  width:100%;padding:11px;border-radius:9px;
  background:var(--gold);color:#000;border:none;
  font-size:13px;font-weight:900;cursor:pointer;margin-top:11px;transition:opacity .15s;letter-spacing:.2px;
}
.s-conf:disabled{opacity:.25;cursor:not-allowed}
.s-conf:not(:disabled):hover{opacity:.85}
.s-warn{font-size:11px;margin-top:7px;padding:8px 10px;border-radius:8px;background:rgba(255,77,77,.1);color:#ffaaaa;display:none;font-weight:600;border:1px solid rgba(255,77,77,.2)}

/* Quick Actions */
.qa{padding:14px 16px;border-top:1px solid var(--border);flex-shrink:0}
.qa-title{font-size:10px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px}
.qa-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:9px}
.qb{padding:11px 7px;border-radius:9px;border:1.5px solid var(--border);background:var(--card);color:var(--text);font-size:12px;font-weight:800;cursor:pointer;text-align:center;transition:all .15s}
.qb.start{border-color:rgba(0,200,150,.35);color:var(--up)}.qb.start:hover{background:rgba(0,200,150,.08)}
.qb.pause{border-color:rgba(240,192,0,.35);color:var(--gold)}.qb.pause:hover{background:rgba(240,192,0,.08)}
.qb.stop{border-color:rgba(255,77,77,.35);color:var(--down)}.qb.stop:hover{background:rgba(255,77,77,.08)}
.qb.reset{border-color:rgba(168,85,247,.35);color:var(--purple)}.qb.reset:hover{background:rgba(168,85,247,.08)}
.ptog{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 13px;background:var(--card);border-radius:9px;
  border:1px solid var(--border);margin-bottom:7px;
}
.ptog-lbl{font-size:11px;font-weight:600;color:var(--muted)}
.ptog-btn{padding:5px 14px;border-radius:12px;border:none;font-size:11px;font-weight:800;cursor:pointer;transition:all .2s}
.ptog-btn.on{background:var(--gold);color:#000}
.ptog-btn.off{background:var(--dim);color:var(--muted)}
.qa-scan{width:100%;padding:10px;border-radius:9px;background:var(--gold-dim);border:1.5px solid rgba(240,192,0,.25);color:var(--gold);font-size:12px;font-weight:800;cursor:pointer;transition:all .15s}
.qa-scan:hover{background:rgba(240,192,0,.18)}

/* Bot Status Bar */
.bsb{padding:12px 16px;background:#0d0d1a;border-top:1px solid var(--border);flex-shrink:0}
.bsb-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px}
.pulse{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px}
.pulse.run{background:var(--up);animation:plz 2s infinite}
.pulse.pau{background:var(--gold)}
.pulse.stp{background:var(--down)}
@keyframes plz{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.75)}}
.bsb-st{font-size:13px;font-weight:900}
.bsb-md{font-size:10px;color:var(--muted);font-weight:600;margin-left:5px}
.bsb-tm{font-size:11px;color:var(--muted);font-weight:600}
.bsb-meta{display:flex;gap:14px;font-size:10px;color:var(--muted);font-weight:600}
.bsb-meta strong{color:var(--text);font-weight:700}

/* ══ MAIN ══ */
.main{flex:1;overflow-y:auto;overflow-x:hidden;display:flex;flex-direction:column;min-width:0}

/* ── Header ── */
.hdr{
  padding:17px 24px 15px;border-bottom:1px solid var(--border);
  display:flex;align-items:flex-end;justify-content:space-between;
  flex-shrink:0;background:#0d0d1a;
}
.bal-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.9px;margin-bottom:5px;font-weight:700}
.bal-val{font-size:42px;font-weight:900;line-height:1;letter-spacing:-1.5px}
.bal-val .cur{font-size:21px;font-weight:500;color:var(--muted);margin-right:2px}
.periods{display:flex;gap:26px;margin-top:10px}
.pd-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px;font-weight:700}
.pd-val{font-size:14px;font-weight:800}
.pd-val.up{color:var(--up)}.pd-val.down{color:var(--down)}.pd-val.nt{color:var(--muted)}
.hdr-right{display:flex;align-items:center;gap:10px}
.scan-chip{font-size:11px;color:var(--muted);padding:7px 14px;background:var(--card);border:1px solid var(--border);border-radius:20px}
.scan-chip span{color:var(--gold);font-weight:800}
.hdr-btn{
  width:37px;height:37px;border-radius:50%;background:var(--card);
  border:1px solid var(--border);display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--muted);font-size:16px;position:relative;transition:all .15s;
}
.hdr-btn:hover{border-color:var(--border2);color:var(--text);background:var(--card2)}
.notif-dot{position:absolute;top:5px;right:5px;width:7px;height:7px;background:var(--gold);border-radius:50%}
.avatar{width:37px;height:37px;border-radius:50%;background:linear-gradient(135deg,var(--gold),#a07800);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:#000;cursor:pointer}

/* ── Scroll content ── */
.content{padding:16px 22px 22px;flex:1}

/* ══ CARD ══ */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:16px}
.ctitle{
  font-size:11px;color:var(--muted);text-transform:uppercase;
  letter-spacing:.6px;margin-bottom:12px;font-weight:700;
  display:flex;align-items:center;justify-content:space-between;
}
.ctitle a{color:var(--gold);cursor:pointer;font-size:10px;text-transform:none;letter-spacing:0;font-weight:700}

/* ══ COIN CARDS ══ */
.coin-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px}
.cc{background:var(--card2);border:1.5px solid var(--border);border-radius:var(--r);padding:16px;cursor:pointer;transition:border-color .2s;overflow:hidden}
.cc:hover{border-color:var(--border2)}
.cc.sel{border-color:var(--gold)}
.cc-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px}
.cc-info{display:flex;align-items:center;gap:9px}
.cc-ico{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;flex-shrink:0}
.cc-name{font-size:13px;font-weight:700}
.cc-tk{font-size:10px;color:var(--muted);font-weight:600}
.cc-arr{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:700;flex-shrink:0}
.cc-arr.up{background:rgba(0,200,150,.15);color:var(--up)}
.cc-arr.down{background:rgba(255,77,77,.15);color:var(--down)}
.cc-price{font-size:20px;font-weight:900;margin-bottom:4px;letter-spacing:-.5px}
.cc-chg{font-size:12px;font-weight:700}
.cc-chg.up{color:var(--up)}.cc-chg.down{color:var(--down)}
.cc-spark{height:42px;margin-top:10px}

/* ══ STATUS STRIP ══ */
.sg{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:14px}
.sc{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:13px}
.sc.gold-b{border-color:rgba(240,192,0,.22)}
.sc-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:7px;font-weight:700}
.sc-val{font-size:19px;font-weight:900;line-height:1}
.sc-sub{font-size:10px;color:var(--muted);margin-top:4px;font-weight:500}
.prog{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:6px}
.prog-fill{height:100%;border-radius:2px;background:var(--gold);transition:width .4s}

/* ══ MIE ══ */
.mie-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
.mc{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px}
.mc-stats{font-size:12px;line-height:2.1;color:var(--muted);margin-top:6px}
.mc-stats strong{color:var(--text);font-weight:700}
.bias-bull{color:var(--up)!important}
.bias-bear{color:var(--down)!important}
.bias-neut{color:var(--gold)!important}

/* ══ TRADES + SIGNALS ══ */
.ts-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px}
.tbl{width:100%;border-collapse:collapse;font-size:12px}
.tbl th{text-align:left;padding:8px 10px;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.3px;border-bottom:1px solid var(--border)}
.tbl td{padding:10px 10px;border-bottom:1px solid var(--border);vertical-align:middle}
.tbl tr:last-child td{border-bottom:none}
.tbl tbody tr:hover{background:rgba(255,255,255,.02)}

/* Tags */
.tag{display:inline-block;padding:3px 9px;border-radius:18px;font-size:10px;font-weight:700;white-space:nowrap}
.tag-up{background:var(--up-bg);color:var(--up)}
.tag-down{background:var(--down-bg);color:var(--down)}
.tag-gold{background:var(--gold-dim);color:var(--gold)}
.tag-blue{background:rgba(91,156,246,.13);color:var(--blue)}
.tag-muted{background:rgba(255,255,255,.06);color:var(--muted)}

/* Signals */
.sr{display:flex;align-items:center;gap:8px;padding:9px 0;border-bottom:1px solid var(--border)}
.sr:last-child{border-bottom:none}
.sr-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.sr-sym{font-size:13px;font-weight:800;min-width:54px}
.sr-dir{width:48px}
.sr-sw{flex:1}
.sr-sb{height:4px;background:var(--border);border-radius:2px;overflow:hidden}
.sr-sf{height:100%;border-radius:2px;background:var(--gold)}
.sr-sl{font-size:10px;color:var(--muted);margin-top:2px;font-weight:600}
.sr-rr{font-size:11px;font-weight:800;min-width:34px;text-align:right;color:var(--muted)}

/* ══ PERFORMANCE ══ */
.perf-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:14px}

/* ══ PUMP/DUMP ALERTS ══ */
.pd-row{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap}
.pd-alert{background:var(--card);border:1.5px solid var(--border);border-radius:10px;padding:10px 14px;flex:1;min-width:160px;max-width:220px}
.pd-alert.pump{border-color:rgba(0,200,150,.35);background:rgba(0,200,150,.06)}
.pd-alert.dump{border-color:rgba(255,77,77,.35);background:rgba(255,77,77,.06)}
.pd-sym{font-size:13px;font-weight:800;margin-bottom:3px}
.pd-type{display:inline-block;font-size:10px;font-weight:800;padding:2px 8px;border-radius:10px;margin-bottom:5px}
.pd-type.pump{background:var(--up-bg);color:var(--up)}
.pd-type.dump{background:var(--down-bg);color:var(--down)}
.pd-conf{font-size:11px;color:var(--muted);font-weight:600}
.pd-sigs{font-size:10px;color:var(--muted);margin-top:4px;line-height:1.5}
.pd-empty{color:var(--muted);font-size:12px;padding:14px;text-align:center;background:var(--card);border:1px solid var(--border);border-radius:10px;flex:1}

/* ══ HELPERS ══ */
.empty{color:var(--muted);font-size:12px;padding:22px;text-align:center}
.up{color:var(--up)}.down{color:var(--down)}.gold{color:var(--gold)}

/* Toast */
#toast{
  position:fixed;bottom:22px;left:calc(var(--wz-w)+18px);
  padding:11px 17px;border-radius:10px;font-size:12px;z-index:9999;
  box-shadow:0 12px 40px rgba(0,0,0,.7);max-width:290px;display:none;
  border:1px solid rgba(255,255,255,.1);color:#fff;font-weight:600;
}
</style>
</head>
<body>

<!-- ══════════ WIZARD (ESQUERDA) ══════════ -->
<aside class="wizard">

  <div class="wz-hdr">
    <div class="wz-logo">TRADER 001</div>
    <div class="wz-title">&#9881; Configuração do Bot</div>
    <div class="wz-sub">Preencha cada etapa em ordem<br>Clique <b>CONFIRMADO</b> para aplicar tudo</div>
    <div class="wz-prog">
      <div class="wz-prog-bar"><div class="wz-prog-fill" id="wzProgFill" style="width:0%"></div></div>
      <div class="wz-prog-txt">
        <span id="wzProgTxt">0 de 5 etapas concluídas</span>
        <span id="wzProgPct">0%</span>
      </div>
    </div>
  </div>

  <div class="wz-body">

    <!-- STEP 1: Modo -->
    <div class="step active" id="step-1">
      <div class="step-hdr" onclick="toggleStep(1)">
        <div class="step-num">1</div>
        <div class="step-ttl">Modo de Execução</div>
        <span class="step-cur" id="sv-1"></span>
        <span class="step-ico" id="si-1">&#9660;</span>
      </div>
      <div class="step-body">
        <div class="og og2">
          <button class="ob" id="ob-sup" onclick="selectMode('SUPERVISED')">
            &#128100;<br><span style="font-size:12px;font-weight:800">Supervisão</span><br>
            <span style="font-size:10px;color:var(--muted)">Aprova manualmente</span>
          </button>
          <button class="ob" id="ob-auto" onclick="selectMode('AUTONOMOUS')">
            &#129302;<br><span style="font-size:12px;font-weight:800">Autônomo</span><br>
            <span style="font-size:10px;color:var(--muted)">Opera sozinho</span>
          </button>
          <button class="ob" id="ob-grid" onclick="selectMode('GRID')">
            &#9889;<br><span style="font-size:12px;font-weight:800">Grid</span><br>
            <span style="font-size:10px;color:var(--muted)">Ciclos automáticos</span>
          </button>
          <button class="ob" id="ob-sinais" onclick="selectMode('SINAIS')">
            &#128225;<br><span style="font-size:12px;font-weight:800">Sinais</span><br>
            <span style="font-size:10px;color:var(--muted)">Só transmite</span>
          </button>
        </div>
      </div>
    </div>

    <!-- STEP 2: Capital -->
    <div class="step locked" id="step-2">
      <div class="step-hdr" onclick="toggleStep(2)">
        <div class="step-num">2</div>
        <div class="step-ttl">Capital e Risco</div>
        <span class="step-cur" id="sv-2"></span>
        <span class="step-ico" id="si-2">&#128274;</span>
      </div>
      <div class="step-body">
        <div class="s-lbl" style="margin-top:0">Capital Total Alocado (USDT)</div>
        <div class="og" style="grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:8px">
          <button class="ob" onclick="setCapPreset(10)">$10</button>
          <button class="ob" onclick="setCapPreset(30)">$30</button>
          <button class="ob" onclick="setCapPreset(100)">$100</button>
          <button class="ob" onclick="setCapPreset(500)">$500</button>
          <button class="ob" onclick="setCapPreset(1000)">$1k</button>
        </div>
        <input type="number" class="s-inp" id="capInput" placeholder="Ou digite o valor em USDT..." min="1" step="10" oninput="onCapInput()">
        <div class="s-lbl">Risco por Trade</div>
        <div class="og" style="grid-template-columns:repeat(4,1fr)">
