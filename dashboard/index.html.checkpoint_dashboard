  document.querySelectorAll('#ob-sup,#ob-auto,#ob-grid,#ob-sinais').forEach(b => b.classList.remove('sel'));
  const btnMap = { SUPERVISED: 'ob-sup', AUTONOMOUS: 'ob-auto', GRID: 'ob-grid', SINAIS: 'ob-sinais' };
  const mLbl   = { SUPERVISED: 'Supervisão', AUTONOMOUS: 'Autônomo', GRID: 'Grid', SINAIS: 'Sinais' };
  const el = $id(btnMap[m]); if (el) el.classList.add('sel');

  if (m === 'SINAIS') {
    ['step-2','step-4'].forEach(id => { const e=$id(id); if(e) e.classList.add('sinais-skip'); });
    wz.vals.capital = 0; wz.vals.risk = 1; wz.vals.leverage = 10;
    unlockStep(2); markDone(2, 'N/A — Sinais');
    unlockStep(4); markDone(4, 'N/A — Sinais');
