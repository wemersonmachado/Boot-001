async function applyAll() {
  const btn = $id('btn-confirm-all');
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Aplicando...'; }

  const modeMap = { SUPERVISED: 'supervisao', AUTONOMOUS: 'autonomo', GRID: 'grid', SINAIS: 'sinais' };
  const pairs   = 'BTCUSDT,ETHUSDT,SOLUSDT,HYPEUSDT';
  const errors  = [];

  try {
    // 1 — Modo
    const r1 = await apiFetch('/settings/mode?mode=' + (modeMap[wz.vals.mode] || wz.vals.mode.toLowerCase()), 'POST');
    if (!r1) errors.push('modo');

    // 2 — Capital (apenas se não for SINAIS)
    if (wz.vals.mode !== 'SINAIS' && wz.vals.capital > 0) {
      const r2 = await apiFetch('/settings/banca?banca=' + wz.vals.capital, 'POST');
      if (!r2) errors.push('capital');
    }

    // 3 — Trades por sessão
    const r3 = await apiFetch('/settings/trades_per_session?count=' + (wz.vals.trades ?? 0), 'POST');
    if (!r3) errors.push('trades');

    // 4 — Alavancagem (apenas se não for SINAIS)
    if (wz.vals.mode !== 'SINAIS') {
      const r4 = await apiFetch('/settings/grid?leverage=' + wz.vals.leverage + '&target=1&pairs=' + pairs, 'POST');
      if (!r4) errors.push('alavancagem');
    }

    // 5 — Perfil
    const profUrl = PROFILE_URL[wz.vals.profile] || '/mode/normal';
    const r5 = await apiFetch(profUrl, 'POST');
    if (!r5) errors.push('perfil');

    if (errors.length === 0) {
      // Tudo OK — notifica Telegram
      await apiFetch('/config/notify', 'POST');
      toast('✅ Configuração aplicada! Notificação enviada no Telegram.', 'success');
      if (btn) { btn.textContent = '✅ Confirmado!'; btn.style.background = 'rgba(100,210,80,.25)'; }
      loadSettings();
    } else {
      toast('Erro em: ' + errors.join(', ') + '. Verifique o servidor.', 'error');
      if (btn) { btn.disabled = false; btn.textContent = '✅ Confirmado'; }
    }
  } catch(e) {
    toast('Erro ao aplicar configuração.', 'error');
    if (btn) { btn.disabled = false; btn.textContent = '✅ Confirmado'; }
  }
}

// ════ CLAUDE BRAIN ════
let _brainEnabled = false;
let _brainCost    = 0.0;
let _brainBudget  = 0.0;
let _brainCalls   = 0;
let _brainPollTimer = null;

async function loadBrainStatus() {
  try {
    const r = await apiFetch('/claude-brain/status');
    if (r) {
      _brainEnabled = r.enabled;
      _brainCost    = r.session_cost   || 0;
      _brainBudget  = r.budget_usd     || 0;
      _brainCalls   = r.session_calls  || 0;
      _updateBrainBtn();
      _updateBrainCostBadge();
    }
  } catch(e) {}
}

function _updateBrainBtn() {
  const btn       = $id('brainBtn');
  const normalBtn = $id('normalBtn');
  if (!btn) return;
  if (_brainEnabled) {
    btn.innerHTML = '🧠 Modo Claude ✦';
    btn.style.borderColor = 'rgba(184,126,251,.9)';
    btn.style.background  = 'rgba(184,126,251,.22)';
    btn.style.color       = '#d4a8ff';
    btn.style.boxShadow   = '0 0 10px rgba(184,126,251,.25)';
    if (normalBtn) normalBtn.style.display = 'inline-block';
    _startBrainCostPoll();
  } else {
    btn.innerHTML = '🧠 Modo Claude';
    btn.style.borderColor = 'rgba(184,126,251,.35)';
    btn.style.background  = 'rgba(184,126,251,.07)';
    btn.style.color       = '#B87EFB';
    btn.style.boxShadow   = 'none';
    if (normalBtn) normalBtn.style.display = 'none';
    _stopBrainCostPoll();
    _updateBrainCostBadge();
  }
}

function _updateBrainCostBadge() {
  let badge = $id('brainCostBadge');
  if (!badge) return;
  if (_brainEnabled && (_brainCalls > 0 || _brainCost > 0)) {
    let txt = `💰 $${_brainCost.toFixed(4)} · ${_brainCalls} análises`;
    if (_brainBudget > 0) {
      const rem = Math.max(0, _brainBudget - _brainCost);
      const pct = Math.min(100, (_brainCost / _brainBudget) * 100);
      txt += ` · restam $${rem.toFixed(4)} (${(100 - pct).toFixed(0)}%)`;
    }
    badge.textContent = txt;
    badge.style.display = 'inline';
  } else {
    badge.style.display = 'none';
  }
}

function _startBrainCostPoll() {
  if (_brainPollTimer) return;
  _brainPollTimer = setInterval(async () => {
    try {
      const r = await apiFetch('/claude-brain/status');
      if (r && r.enabled) {
        _brainCost   = r.session_cost  || 0;
        _brainCalls  = r.session_calls || 0;
        _brainBudget = r.budget_usd    || 0;
        _updateBrainCostBadge();
      }
    } catch(e) {}
  }, 15000); // atualiza a cada 15s
}

function _stopBrainCostPoll() {
  if (_brainPollTimer) { clearInterval(_brainPollTimer); _brainPollTimer = null; }
}

async function toggleBrain() {
  if (_brainEnabled) return; // use deactivateBrain() to turn off
  if (!confirm('⚠️ Ativar Claude AI como filtro de trades?\n\nCada sinal será analisado pela API do Claude antes de executar.\n\nRequer ANTHROPIC_API_KEY configurada no .env\n(console.anthropic.com → API Keys)')) return;
  const btn = $id('brainBtn');
  btn.disabled = true;
  try {
    const r = await apiFetch('/claude-brain/toggle', 'POST');
    if (r) {
      _brainEnabled = r.enabled;
      _updateBrainBtn();
      toast('🧠 Claude AI ativado — notificação enviada no Telegram', 'success');
    }
  } catch(e) {
    toast('Erro: verifique se ANTHROPIC_API_KEY está configurada no .env', 'error');
  } finally {
    btn.disabled = false;
  }
}

async function deactivateBrain() {
  if (!_brainEnabled) return;
  if (!confirm('Desativar Claude AI e voltar ao modo de análise tradicional?')) return;
  const normalBtn = $id('normalBtn');
  if (normalBtn) normalBtn.disabled = true;
  try {
    const r = await apiFetch('/claude-brain/toggle', 'POST');
    if (r) {
      _brainEnabled = r.enabled;
      _updateBrainBtn();
      toast('🔧 Modo Normal restaurado — resumo enviado no Telegram', 'info');
    }
  } catch(e) {
    toast('Erro ao desativar Claude AI', 'error');
  } finally {
    if (normalBtn) normalBtn.disabled = false;
  }
}

