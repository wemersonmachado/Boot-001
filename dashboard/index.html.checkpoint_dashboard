async function loadSRZones() {
  const d = await apiFetch('/signals/zones/BTCUSDT');
  if (!d || !d.zones) return;
  const z = d.zones;
  const price = z.current_price || 0;
  const resist = z.nearest_resistance;
  const support = z.nearest_support;
  if (resist) {
    const distR = price > 0 ? ((resist.level - price) / price * 100).toFixed(1) : '?';
    set('sw-resist', `$${fmt(resist.level)} <span style="font-size:10px;color:var(--muted)">+${distR}%</span>`);
  }
  if (support) {
    const distS = price > 0 ? ((price - support.level) / price * 100).toFixed(1) : '?';
    set('sw-support', `$${fmt(support.level)} <span style="font-size:10px;color:var(--muted)">-${distS}%</span>`);
  }
}

