async function loadSettings() {
  const d = await apiFetch('/settings');
  if (!d) return;
  _paperMode = d.paper_trading || false;
  refreshPaperBtn();

  if (wz.vals.mode === null) {
    const m   = (d.operation_mode || 'SINAIS').toUpperCase();
    wz.vals.mode = m;
    const map = { SUPERVISED: 'ob-sup', AUTONOMOUS: 'ob-auto', GRID: 'ob-grid', SINAIS: 'ob-sinais' };
    const el  = map[m] && $id(map[m]);
    if (el) el.classList.add('sel');
    const sc1 = $id('sc-1'); if (sc1) sc1.disabled = false;
    if (m === 'SINAIS') {
      // Mostra hints de "Desativado" nas etapas 2 e 4 desde o carregamento inicial
      txt('sv-2', 'Desativado'); txt('sv-4', 'Desativado');
    }
  }
  if (wz.vals.capital === null) {
    const cap = parseFloat(d.banca_usdt || 0);
    wz.vals.capital = cap;
    wz.temp.capital = cap;
    const inp = $id('capInput');
    if (inp && cap > 0) inp.value = cap;
    wz.vals.risk = 1; wz.temp.risk = 1;
    const rb1 = $id('rb-1'); if (rb1) rb1.classList.add('sel');
    const sc2 = $id('sc-2'); if (sc2) sc2.disabled = false;
  }
  if (wz.vals.trades === null) {
    const isSinais = (d.operation_mode || '').toUpperCase() === 'SINAIS';
    wz.vals.trades = isSinais ? 0 : (d.trades_per_session != null ? d.trades_per_session : 3);
    if (isSinais) txt('sv-3', 'Ilimitado');
    const sc3 = $id('sc-3'); if (sc3) sc3.disabled = false;
  }
  if (wz.vals.leverage === null) {
    wz.vals.leverage = d.grid_leverage || 10;
    const sc4 = $id('sc-4'); if (sc4) sc4.disabled = false;
  }
  if (wz.vals.profile === null) {
    const pr  = (d.trading_mode || 'NORMAL').toUpperCase();
    wz.vals.profile = pr;
    const el2 = $id(PROFILE_BTN[pr] || 'ob-norm');
    if (el2) el2.classList.add('sel');
    const sc5 = $id('sc-5'); if (sc5) sc5.disabled = false;
  }

  // Popula watchlist inputs
  const supWl    = (d.supervised_watchlist || []).map(s => s.replace('USDT', '')).join(',');
  const autoWl   = (d.autonomous_watchlist || []).map(s => s.replace('USDT', '')).join(',');
  const gridWl   = (d.grid_pairs           || []).map(s => s.replace('USDT', '')).join(',');
  const sinaisWl = (d.sinais_watchlist     || []).map(s => s.replace('USDT', '')).join(',');
  if ($id('wl-sup')    && supWl)    $id('wl-sup').value    = supWl;
  if ($id('wl-auto')   && autoWl)   $id('wl-auto').value   = autoWl;
  if ($id('wl-grid')   && gridWl)   $id('wl-grid').value   = gridWl;
  if ($id('wl-sinais') && sinaisWl) $id('wl-sinais').value = sinaisWl;

  updateStatusBar(d);
  updateStepValues();
  // Unlock steps that have their pre-conditions met
  const prereq = [
    wz.vals.mode !== null,      // unlocks step 2
    wz.vals.capital !== null,   // unlocks step 3
    wz.vals.trades !== null,    // unlocks step 4
    wz.vals.leverage !== null,  // unlocks step 5
  ];
  [2, 3, 4, 5].forEach((n, i) => { if (prereq[i]) unlockStep(n); });
}

