// ════ UTILS ════
function fmt(v, d = 2) {
  const f = parseFloat(v);
  if (v == null || v === '' || isNaN(f)) return '--';
  return f.toLocaleString('pt-BR', { minimumFractionDigits: d, maximumFractionDigits: d });
}
function sign(v) { return parseFloat(v) >= 0 ? '+' : ''; }
function cls(v)  { return parseFloat(v) >= 0 ? 'up' : 'down'; }
function pct(v)  { return sign(v) + fmt(v) + '%'; }
function pnlH(v) {
  const f = parseFloat(v || 0);
  return `<span class="${cls(f)}">${sign(f)}$${fmt(Math.abs(f))}</span>`;
}
function set(id, html) { const e = document.getElementById(id); if (e) e.innerHTML = html; }
function txt(id, t)    { const e = document.getElementById(id); if (e) e.textContent = t; }
function $id(id)       { return document.getElementById(id); }

function toast(msg, type = 'info') {
  const t = $id('toast');
  if (!t) return;
  const bg = { info: '#161630', success: '#0d2a1f', error: '#2a0d0d', warn: '#2a1a00' };
  const bc = { info: '#3344aa44', success: '#00c89644', error: '#ff4d4d44', warn: '#f0c00044' };
  t.style.cssText = `position:fixed;bottom:22px;left:calc(var(--wz-w)+18px);
    padding:11px 17px;border-radius:10px;font-size:12px;z-index:9999;font-weight:600;
    box-shadow:0 12px 40px rgba(0,0,0,.7);max-width:290px;display:block;opacity:1;transition:opacity .25s;
    background:${bg[type]||bg.info};border:1px solid ${bc[type]||bc.info};color:#eeeef5;`;
  t.textContent = msg;
  clearTimeout(t._t);
  t._t = setTimeout(() => {
    t.style.opacity = '0';
    setTimeout(() => { t.style.display = 'none'; }, 280);
  }, 3500);
}

async function apiFetch(path, method = 'GET') {
  const t0 = Date.now();
  try {
    const ctrl = new AbortController();
    const tid  = setTimeout(() => ctrl.abort(), 10000);
    const r    = await fetch(API + path, { method, signal: ctrl.signal });
    clearTimeout(tid);
    const lat = Date.now() - t0;
    const el  = $id('latDisp');
    if (el) { el.textContent = lat + 'ms'; el.style.color = lat < 300 ? 'var(--up)' : lat < 800 ? 'var(--gold)' : 'var(--down)'; }
    if (!r.ok) return null;
    return await r.json();
  } catch (e) {
    return null;
  }
}

// ════ SPARKLINES ════
function drawSparkline(canvasId, prices, isUp) {
  const canvas = $id(canvasId);
  if (!canvas || !prices || prices.length < 2) return;
  const w     = canvas.parentElement.offsetWidth || 200;
  const h     = 42;
  canvas.width = w; canvas.height = h;
  const ctx   = canvas.getContext('2d');
  const min   = Math.min(...prices), max = Math.max(...prices);
  const range = max - min || 1;
  const color = isUp ? '#00C896' : '#FF4D4D';
  ctx.clearRect(0, 0, w, h);
  ctx.beginPath();
  prices.forEach((p, i) => {
    const x = (i / (prices.length - 1)) * w;
    const y = h - 4 - ((p - min) / range) * (h - 8);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.strokeStyle = color; ctx.lineWidth = 1.8;
  ctx.shadowColor = color; ctx.shadowBlur = 5;
  ctx.stroke(); ctx.shadowBlur = 0;
  const last = canvas.getContext('2d').getImageData(0, 0, 1, 1); // dummy — keep ctx reference
  // fill gradient below line
  const lastX = w;
  const lastY = h - 4 - ((prices[prices.length - 1] - min) / range) * (h - 8);
  ctx.lineTo(lastX, h); ctx.lineTo(0, h); ctx.closePath();
  const grad = ctx.createLinearGradient(0, 0, 0, h);
  grad.addColorStop(0, color + '44');
  grad.addColorStop(1, color + '00');
  ctx.fillStyle = grad; ctx.fill();
}

async function loadSparklines() {
  await Promise.all(['BTC', 'ETH', 'SOL', 'HYPE'].map(async coin => {
    const d = await apiFetch(`/sparkline/${coin}USDT?interval=1h&limit=36`);
    if (d && d.prices && d.prices.length > 1) {
      _sparkData[coin] = d.prices;
      const chgEl = $id('chg-' + coin);
      const isUp  = !(chgEl && chgEl.classList.contains('down'));
      drawSparkline('spark-' + coin, d.prices, isUp);
    }
  }));
}

