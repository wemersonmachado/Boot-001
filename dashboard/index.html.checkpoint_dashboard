// ════ WIZARD LOGIC ════
function toggleStep(n) {
  const el = $id('step-' + n);
  if (!el || el.classList.contains('locked') || el.classList.contains('sinais-skip')) return;
  const body = el.querySelector('.step-body');
  if (wz.completed.has(n)) {
    // Toggle body on already-completed steps
    if (body) body.style.display = body.style.display === 'none' ? 'block' : 'none';
  } else {
    setActiveStep(n);
  }
}

function setActiveStep(n) {
  for (let i = 1; i <= 5; i++) {
    const el   = $id('step-' + i); if (!el) continue;
    const body = el.querySelector('.step-body');
    if (i === n) {
      if (!el.classList.contains('locked')) {
        el.classList.add('active');
        if (body) body.style.display = 'block';
      }
    } else if (!wz.completed.has(i)) {
      el.classList.remove('active');
      if (body) body.style.display = 'none';
    }
  }
}

function unlockStep(n) {
  const el  = $id('step-' + n); if (!el) return;
  el.classList.remove('locked');
  const ico = $id('si-' + n);
  if (ico) ico.innerHTML = '&#9660;'; // always set to chevron when unlocked
}

function markDone(n, display) {
  const el = $id('step-' + n); if (!el) return;
  el.classList.remove('active'); el.classList.add('done');
  const body = el.querySelector('.step-body');
  if (body) body.style.display = 'none';
  const num = el.querySelector('.step-num');
  if (num) num.innerHTML = '&#10003;';
  const ico = $id('si-' + n);
  if (ico) ico.innerHTML = '&#9998;';
  if (display) txt('sv-' + n, display);
  wz.completed.add(n);
  updateProgress();
}

function updateProgress() {
  const p = (wz.completed.size / 5) * 100;
  const f = $id('wzProgFill'); if (f) f.style.width = p + '%';
  txt('wzProgTxt', wz.completed.size + ' de 5 etapas concluídas');
  txt('wzProgPct', Math.round(p) + '%');
}

